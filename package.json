{
  "name": "@internetarchive/your-webcomponent",
  "description": "The Internet Archive Typescript WebComponent template.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/internetarchive/iaux-your-webcomponent.git"
  },
  "license": "AGPL-3.0-only",
  "author": "Internet Archive",
  "version": "0.0.0",
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "scripts": {
    "start": "vite serve demo",
    "prepare": "vite build",
    "build": "vite build",
    "lint": "eslint . && prettier \"**/*.ts\" --check",
    "format": "eslint . --fix && prettier \"**/*.ts\" --write",
    "circular": "madge --circular --extensions ts .",
    "test": "pnpm run lint && pnpm run circular && vitest run",
    "test:watch": "vitest",
    "ghpages:build": "pnpm run prepare && vite build --config vite.ghpages.config.ts",
    "ghpages:publish": "pnpm run ghpages:prepare -e $(git branch --show-current)",
    "ghpages:prepare": "pnpm run ghpages:build && touch ghpages/.nojekyll && pnpm run ghpages:generate",
    "ghpages:generate": "gh-pages -t -d ghpages -m \"Build for $(git log --pretty=format:\"%h %an %ai %s\" -n1) [skip ci]\""
  },
  "types": "dist/index.d.ts",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "axe-core": "^4.12.1",
    "eslint": "^10.6.0",
    "eslint-plugin-html": "^8.1.4",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "madge": "^8.0.0",
    "path": "^0.12.7",
    "playwright": "^1.61.1",
    "prettier": "^3.9.4",
    "rimraf": "^6.1.3",
    "ts-lit-plugin": "^2.0.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.2",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "public"
  },
  "prettier": {
    "singleQuote": true,
    "arrowParens": "avoid"
  },
  "files": [
    "README.md",
    "dist"
  ],
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write",
      "git add"
    ]
  },
  "dependencies": {
    "lit": "^2.8.0 || ^3.3.2"
  }
}
